datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

model Student {
  studentId                Int             @id
  name                     String
  paidStatus               Int             // 0 = unpaid, 1 = paid
  passwordHash             String?
  currentWebAuthnChallenge String?
  authenticators           Authenticator[]
  mealRedemptions          MealRedemption[]
}

model Authenticator {
  credentialID         String  @id
  credentialPublicKey  Bytes
  counter              BigInt
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  studentId            Int
  student              Student @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
}

model MealRedemption {
  id         Int      @id @default(autoincrement())
  studentId  Int
  date       String   // Format: YYYY-MM-DD
  mealSlot   String   // '01' (Breakfast), '02' (Lunch), '03' (Dinner)
  redeemedAt DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  wardenId   Int?
  warden     Warden?  @relation(fields: [wardenId], references: [id], onDelete: SetNull)

  @@unique([studentId, date, mealSlot])
}

model Warden {
  id           Int              @id @default(autoincrement())
  username     String           @unique
  name         String
  passwordHash String
  redemptions  MealRedemption[]
}

model DailyMenu {
  date      String @id // Format: YYYY-MM-DD
  breakfast String?
  lunch     String?
  dinner    String?
}
