datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

model Student {
  studentId                Int             @id
  name                     String
  paidStatus               Int             // 0 = unpaid, 1 = paid
  passwordHash             String?
  currentWebAuthnChallenge String?
  authenticators           Authenticator[]
  mealRedemptions          MealRedemption[]
  orders                   Order[]
}

model Authenticator {
  credentialID         String  @id
  credentialPublicKey  Bytes
  counter              BigInt
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  studentId            Int
  student              Student @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
}

model MealRedemption {
  id         Int      @id @default(autoincrement())
  studentId  Int
  date       String   // Format: YYYY-MM-DD
  mealSlot   String   // '01' (Breakfast), '02' (Lunch), '03' (Dinner)
  redeemedAt DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  wardenId   Int?
  warden     Warden?  @relation(fields: [wardenId], references: [id], onDelete: SetNull)

  @@unique([studentId, date, mealSlot])
  @@index([date])
}

model Warden {
  id           Int              @id @default(autoincrement())
  username     String           @unique
  name         String
  passwordHash String
  role         String           @default("HOSTEL_WARDEN") // 'HOSTEL_WARDEN' | 'VENDOR_ADMIN'
  vendorId     Int?
  vendor       Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  redemptions  MealRedemption[]
}

model DailyMenu {
  date      String @id // Format: YYYY-MM-DD
  breakfast String?
  lunch     String?
  dinner    String?
}

model Vendor {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  isActive  Boolean     @default(true)
  menuItems MenuItem[]
  orders    Order[]
  wardens   Warden[]
}

model MenuItem {
  id          Int         @id @default(autoincrement())
  vendorId    Int
  vendor      Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name        String
  price       Float
  isAvailable Boolean     @default(true)
  imageUrl    String?
  orderItems  OrderItem[]
}

model Order {
  id          Int         @id @default(autoincrement())
  orderNumber String      @unique
  studentId   Int
  student     Student     @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  vendorId    Int
  vendor      Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  totalAmount Float
  status      String      @default("Pending") // 'Pending', 'Ready', 'PickedUp'
  createdAt   DateTime    @default(now())
  items       OrderItem[]

  @@index([vendorId, status])
  @@index([studentId, status])
}

model OrderItem {
  id                 Int      @id @default(autoincrement())
  orderId            Int
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId         Int
  menuItem           MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  quantity           Int
  priceAtTimeOfOrder Float
}
